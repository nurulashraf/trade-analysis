# ----- data -----
# mock = deterministic offline demo data (default), yfinance = real daily candles
DATA_PROVIDER=mock
# Per-tab watchlists (Yahoo Finance symbols: futures =F, forex =X):
# WATCHLIST_STOCKS=NVDA,AAPL,5347.KL
# WATCHLIST_COMMODITIES=GC=F,CL=F
# WATCHLIST_FOREX=EURUSD=X,USDMYR=X
# Legacy flat override also works (auto-sorted into tabs by suffix):
# WATCHLIST=NVDA,AMD,INTC,5347.KL

# ----- brains: who debates the trades -----
# Offline default: two rule-based personas that must agree.
BRAINS=rule:momentum,rule:meanrev
# Real LLM examples (any mix; the bot trades only when REQUIRED_AGREEMENT agree):
# BRAINS=kimi:,deepseek:
# BRAINS=anthropic:claude-haiku-4-5-20251001,kimi:kimi-k2-0905-preview
REQUIRED_AGREEMENT=2

# ANTHROPIC_API_KEY=
# MOONSHOT_API_KEY=      # Kimi
# DEEPSEEK_API_KEY=
# OPENAI_API_KEY=        # for BRAINS=openai-compat:<base_url>|<model>

# ----- risk -----
STARTING_CASH=10000
MAX_POSITION_PCT=0.15        # max 15% of equity in one stock
MAX_DAILY_LOSS_PCT=0.03      # kill-switch: halt if down 3% on the day
TRADE_COOLDOWN_SEC=120
MIN_CONFIDENCE=0.6
TICK_SECONDS=4

# ----- live trading (leave these alone unless you truly mean it) -----
# Real-money trading needs a running moomoo OpenD gateway, `pip install moomoo-api`,
# AND both flags below. Anything less and the app stays in paper mode.
LIVE_TRADING_ENABLED=false
LIVE_TRADING_CONFIRM=
